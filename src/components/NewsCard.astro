---
import { Image } from "astro:assets";
import Buttons from "./Buttons.astro";
import { Icon } from "astro-icon/components";
import type { SectionSampleLinkType, NotionPageType } from "@types";

interface Props {
  noticia: NotionPageType;
  link?: SectionSampleLinkType;
  short?: boolean;
  className?: string;
  index?: number;
  Content?: any;
}

const {
  noticia,
  short,
  link,
  className = "",
  index = 0,
  Content,
} = Astro.props;
---

<div
  id={noticia.url}
  class={`card ${className} card-md md:card-lg bg-base-300 shadow`}
>
  {
    noticia.Imagen && (
      <figure class="w-full aspect-[5/3] overflow-hidden flex items-center justify-center bg-base-200">
        <Image
          src={noticia.Imagen}
          alt={noticia.Nombre}
          width={typeof noticia.width === "number" ? noticia.width : 192}
          height={typeof noticia.height === "number" ? noticia.height : 128}
          sizes={
            short
              ? "(max-width: 768px) 128px, 192px"
              : "(max-width: 768px) 192px, 256px"
          }
          class="object-cover w-full h-full"
          style="display:block;"
          loading={index < 4 ? "eager" : "lazy"}
        />
      </figure>
    )
  }

  <div class={`card-body w-full ${short ? "p-6" : ""}`}>
    <h2 class="card-title" aria-label={noticia.Nombre}>
      {noticia.Nombre}
    </h2>

    <div class="card-content flex flex-col gap-2">
      {
        Content ? (
          <Content />
        ) : noticia.Contenido ? (
          (() => {
            // Quita bloques de iframe
            const contenidoSinIframe = noticia.Contenido.replace(/<iframe[\s\S]*?<\/iframe>/gi, "");
            return contenidoSinIframe.substring(0, 160) + "...";
          })()
        ) : (
          "Noticia del Canarias Racing Team"
        )
      }
    </div>

    <slot />
    <div class="card-actions justify-between place-items-center">
      {
        short ? (
          <div class="flex flex-col gap-1">
            {noticia.Autor && (
              <div class="badge badge-soft">
                <Icon name="mdi:account" class="size-[1em] mr-1" />
                {noticia.Autor}
              </div>
            )}

            {noticia.Fecha && (
              <div class="badge badge-soft">
                <Icon name="mdi:calendar" class="size-[1em] mr-1" />
                {new Date(noticia.Fecha).toLocaleDateString("es-ES", {
                  year: "numeric",
                  month: short ? "short" : "long",
                  day: "numeric",
                })}
              </div>
            )}
          </div>
        ): null
      }

      {
        link && (
          <div class="w-full flex justify-end md:justify-end">
            <Buttons
              buttons={[
                { text: link.text, href: link.href, icon: "mdi:arrow-right" },
              ]}
              className=""
            />
          </div>
        )
      }
    </div>
  </div>
</div>
