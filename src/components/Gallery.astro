---
import { Image } from "astro:assets";
import type { ImageEntry } from "@types";

const {
  items = [],
  className = "",
  invert = true,
  scale = "max-w-full max-h-full",
  href,
} = Astro.props;

const resolvedItems =
  items.length > 0
    ? await Promise.all(
        items.map(async (item: ImageEntry) => ({
          alt: item.alt ?? item.name ?? "Imagen",
          src: item.src,
          href: (item as any).href ?? (item as any).a ?? href,
          isExternal: (() => {
            const h = (item as any).href ?? (item as any).a ?? "";
            return (
              typeof h === "string" &&
              (h.startsWith("http://") ||
                h.startsWith("https://") ||
                h.startsWith("//"))
            );
          })(),
          invert: (() => {
            let v = (item as any).invert ?? invert;
            if (typeof v === "string") {
              v = v.toLowerCase() === "true" || v === "1";
            }
            return !!v;
          })(),
          // allow passing a full Tailwind size class (e.g. "max-w-[65%] max-h-[65%]")
          // otherwise fall back to the component-level `scale` default
          scale: (item as any).scale ?? scale,
        })),
      )
    : [];
---

<div
  class={`grid grid-cols-5 gap-0 w-full h-full max-h-full overflow-hidden items-center ${className}`}
>
  {
    resolvedItems.map((item) => (
      <div class="flex items-center justify-center h-full max-h-full p-0 overflow-hidden">
        {item.href ? (
          <a
            href={item.href}
            class="w-full h-full flex items-center justify-center"
            target={item.isExternal ? "_blank" : undefined}
            rel={item.isExternal ? "noopener noreferrer" : undefined}
          >
            <Image
              src={item.src}
              alt={item.alt}
              sizes="(max-width: 768px) 80px, 138px"
              loading="lazy"
              inferSize={true}
              class={`${item.scale} object-contain filter grayscale ${item.invert ? "invert hover:invert-0" : ""} hover:grayscale-0 transition-all duration-300`}
            />
          </a>
        ) : (
          <Image
            src={item.src}
            alt={item.alt}
            sizes="(max-width: 768px) 80px, 138px"
            loading="lazy"
            inferSize={true}
            class={`${item.scale} object-contain filter grayscale ${item.invert ? "invert hover:invert-0" : ""} hover:grayscale-0 transition-all duration-300`}
          />
        )}
      </div>
    ))
  }
</div>
