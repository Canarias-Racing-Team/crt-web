---
import NewsCard from "@components/NewsCard.astro";
import Layout from "@layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { NotionPageType } from "@/types";
import Section from "@components/Section.astro";
import Card from "@components/Card.astro";
import { texts, createCardContent } from "@utils/texts";
import { getLocalNewsImage } from "@utils/imageUtils";

export const prerender = false;

const entries = await getCollection("news");
const noticiasRaw: NotionPageType[] = entries
  .filter((e) => (e.data?.published ?? true) === true)
  .map((e) => ({
    Publicado: e.data?.published ?? true,
    Contenido: typeof (e as any).body === "string" ? (e as any).body : "",
    Fecha: e.data?.date ? new Date(e.data.date).toISOString() : "",
    Imagen: e.data?.image ?? "",
    url: e.data?.slug ?? e.id,
    Nombre: e.data?.title ?? e.id,
    Autor: e.data?.author ?? "",
  }));

// Usar imágenes locales
const noticias: NotionPageType[] = noticiasRaw.map((noticia) => {
  const imagenLocal = getLocalNewsImage(noticia.url);
  return {
    ...noticia,
    Imagen: imagenLocal || noticia.Imagen || "/og-image-3_4.png",
  };
});

// Puedes definir cuántos placeholders añadir aquí
const placeholdersCount = 0;

for (let i = 0; i < placeholdersCount; i++) {
  noticias.push({
    Nombre: texts.placeholders.news.title,
    Contenido: texts.placeholders.news.content,
    Imagen: "/og-image-3_4.png",
    url: `proximamente-${i + 1}`,
    Publicado: false,
    Fecha: "",
  });
}
---

<Layout
  id={Astro.self.name}
  title="Noticias"
  description="Últimas noticias del equipo Canarias Racing Team. Competiciones, logros, eventos y novedades del primer equipo de Formula Student de Canarias."
  path="/news"
>
  <Section id="news" className="py-15 gap-4">
    <div
      id="content"
      class="w-full grid grid-cols-1 lg:grid-cols-4 gap-4 mb-8 mt-4 lg:mt-0 h-fit"
    >
      {
        noticias
          .slice()
          .sort(
            (a, b) => new Date(b.Fecha).getTime() - new Date(a.Fecha).getTime(),
          )
          .map((noticia, idx) => (
            <NewsCard
              noticia={noticia}
              short
              link={{ href: `/news/${noticia.url}`, text: "Leer más" }}
              index={idx}
            />
          ))
      }
    </div>
  </Section>
</Layout>
